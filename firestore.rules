rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    match /syncs/{syncId} {
      // The app uses a custom (non-firebase) username-based login. 
      // For functionality required immediately, we allow open access.
      allow read, write: if true;
    }
  }
}
